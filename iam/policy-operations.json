{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:StartInstances",
        "ec2:StopInstances",
        "workspaces:DescribeWorkspaces",
        "workspaces:StartWorkspaces",
        "workspaces:StopWorkspaces",
        "cloudwatch:GetDashboard",
        "cloudwatch:GetMetricData",
        "lambda:InvokeFunction"
      ],
      "Resource": "*"
    }
  ]
}
